<UserControl x:Class="Myself.SmartParking.Views.Pages.RechargeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Myself.SmartParking.Views.Pages"
             xmlns:zxc="clr-namespace:Myself.SmartParking.Controls;assembly=Myself.SmartParking.Controls"
             mc:Ignorable="d" Template="{StaticResource PageTempalte}" Tag="充值记录"
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid Margin="10,5">
        <Grid.RowDefinitions>
            <RowDefinition Height="30"/>
            <RowDefinition/>
            <RowDefinition Height="50"/>
        </Grid.RowDefinitions>

        <Border Background="#F7F9FA" Height="1" VerticalAlignment="Bottom"/>
        <Grid TextBlock.FontSize="12" TextBlock.FontWeight="Bold" TextBlock.Foreground="#666">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="50"/>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="90"/>
                <ColumnDefinition Width="90"/>
                <ColumnDefinition Width="150"/>
                <ColumnDefinition Width="150"/>
                <ColumnDefinition Width="50"/>
                <ColumnDefinition Width="150"/>
                <ColumnDefinition Width="90" />
                <ColumnDefinition Width="60"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="序号" VerticalAlignment="Center" HorizontalAlignment="Center" Grid.Column="0"/>
            <TextBlock Text="车牌号" VerticalAlignment="Center" HorizontalAlignment="Left" Grid.Column="1"/>
            <TextBlock Text="计费模式" VerticalAlignment="Center" HorizontalAlignment="Center" Grid.Column="2"/>
            <TextBlock Text="充值有效次数" VerticalAlignment="Center" HorizontalAlignment="Center" Grid.Column="3"/>
            <TextBlock Text="充值起始时间" VerticalAlignment="Center" HorizontalAlignment="Center" Grid.Column="4"/>
            <TextBlock Text="充值结束时间" VerticalAlignment="Center" HorizontalAlignment="Center" Grid.Column="5"/>
            <TextBlock Text="状态" VerticalAlignment="Center" HorizontalAlignment="Center" Grid.Column="6"/>
            <TextBlock Text="续费时间" VerticalAlignment="Center" HorizontalAlignment="Center" Grid.Column="7"/>
            <TextBlock Text="操作人" VerticalAlignment="Center" HorizontalAlignment="Center" Grid.Column="8"/>
            <TextBlock Text="操作" VerticalAlignment="Center" HorizontalAlignment="Center" Grid.Column="9"/>
        </Grid>

        <ListBox Grid.Row="1" ItemsSource="{Binding RechargeList}" BorderThickness="0"
             AlternationCount="2" ItemContainerStyle="{StaticResource NoramalListBoxItemStyle}">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Grid Height="33" Name="root" Background="Transparent">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="50"/>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="90"/>
                            <ColumnDefinition Width="90"/>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition Width="50"/>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition Width="90" />
                            <ColumnDefinition Width="60"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{Binding Index}" Grid.Column="0" VerticalAlignment="Center" 
                               HorizontalAlignment="Center" Foreground="#888"/>
                        <TextBlock Text="{Binding AutoLisence}" Grid.Column="1" VerticalAlignment="Center"
                               Foreground="#888" FontWeight="Bold"/>
                        <TextBlock Text="{Binding FeeModeName}" Grid.Column="2" VerticalAlignment="Center"
                               HorizontalAlignment="Center" Foreground="#888"/>
                        <TextBlock Text="{Binding RechargeCount}" Grid.Column="3" VerticalAlignment="Center" 
                               HorizontalAlignment="Center" Foreground="#888"/>
                        <TextBlock Text="{Binding RechargeStartTime,StringFormat='yyyy-MM-dd HH:mm:ss'}" Grid.Column="4" VerticalAlignment="Center" 
                               HorizontalAlignment="Center" Foreground="#888"/>
                        <TextBlock Text="{Binding RechargeEndTime,StringFormat='yyyy-MM-dd HH:mm:ss'}" Grid.Column="5" VerticalAlignment="Center" 
                               HorizontalAlignment="Center" Foreground="#888"/>
                        <TextBlock Text="作废" Grid.Column="6" VerticalAlignment="Center" 
                               HorizontalAlignment="Center" Foreground="#888"
                               Name="tb_state"/>
                        <TextBlock Text="{Binding CreateTime,StringFormat='yyyy-MM-dd HH:mm:ss'}" 
                               Grid.Column="7" VerticalAlignment="Center" HorizontalAlignment="Center"
                               Foreground="#888"/>
                        <TextBlock Text="{Binding CreateName}" Grid.Column="8" VerticalAlignment="Center" 
                                TextWrapping="Wrap" Foreground="#888" HorizontalAlignment="Center"/>

                        <StackPanel Grid.Column="9" VerticalAlignment="Center" HorizontalAlignment="Center" Orientation="Horizontal">
                            <TextBlock Margin="3,0">
                            <Hyperlink Command="{Binding DataContext.DeleteCommand,RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                       CommandParameter="{Binding}"
                                       IsEnabled="{Binding IsCanCancel}">作废</Hyperlink>
                            </TextBlock>
                        </StackPanel>
                    </Grid>
                    <DataTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#EEE" TargetName="root"/>
                        </Trigger>
                        <DataTrigger Binding="{Binding State}" Value="1">
                            <Setter TargetName="tb_state" Property="Text" Value="正常"/>
                        </DataTrigger>
                    </DataTemplate.Triggers>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>



        <zxc:Pagination DataContext="{Binding PaginationModel}"
                Grid.Row="2" HorizontalAlignment="Center"/>
    </Grid>
</UserControl>
