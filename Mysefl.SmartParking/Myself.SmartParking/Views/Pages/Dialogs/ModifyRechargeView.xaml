<UserControl x:Class="Myself.SmartParking.Views.Pages.Dialogs.ModifyRechargeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Myself.SmartParking.Views.Pages.Dialogs"
             mc:Ignorable="d" Template="{StaticResource DialogViewTemplate}"
             d:DesignHeight="250" d:DesignWidth="400">
    <Grid Margin="20,5" TextBlock.Foreground="#777" FocusManager.FocusedElement="{Binding ElementName=tb}">
        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="90"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>


        <TextBlock Text="车牌号" VerticalAlignment="Center"/>
        <TextBlock Text="计费模式" Grid.Row="1" VerticalAlignment="Center"/>
        <TextBlock Text="有效次数" Grid.Row="2" VerticalAlignment="Center"/>
        <TextBlock Text="有效期" Grid.Row="3" VerticalAlignment="Center"/>

        <ComboBox Grid.Column="1" Height="30" ItemsSource="{Binding AutoList}"
                  SelectedItem="{Binding RechargeInfo.AutoLisence}"/>
        <ComboBox Grid.Column="1" Grid.Row="1" Height="30" ItemsSource="{Binding FeeModeList}"
                  DisplayMemberPath="FeeModeName"
                  SelectedValuePath="FeeModeId"
                  SelectedValue="{Binding RechargeInfo.FeeModeId}"/>
        <TextBox Grid.Row="2" Grid.Column="1" Style="{StaticResource NormalTextBoxStyle}" Height="30"
             Text="{Binding RechargeInfo.RechargeCount}"/>
        <DatePicker Grid.Row="3" Grid.Column="1" Height="30"
                SelectedDateFormat="Long"
                SelectedDate="{Binding RechargeInfo.RechargeEndTime}"/>

    </Grid>
</UserControl>
