<Window x:Class="Mysefl.SmartParking.Simulation.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Mysefl.SmartParking.Simulation"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition/>
            <ColumnDefinition/>
            <ColumnDefinition/>
            <ColumnDefinition Width="auto"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="30"/>
            <RowDefinition Height="30"/>
            <RowDefinition/>
        </Grid.RowDefinitions>
        <Border Background="#EEE" Grid.ColumnSpan="5"/>
        <TextBlock Text="入口相机" VerticalAlignment="Center" HorizontalAlignment="Center"/>
        <TextBlock Text="入口道闸" VerticalAlignment="Center" HorizontalAlignment="Center"
           Grid.Column="1"/>
        <TextBlock Text="出口相机" VerticalAlignment="Center" HorizontalAlignment="Center"
           Grid.Column="2"/>
        <TextBlock Text="出口道闸" VerticalAlignment="Center" HorizontalAlignment="Center"
           Grid.Column="3"/>
        <TextBlock Text="支付提示" VerticalAlignment="Center" HorizontalAlignment="Center"
           Grid.Column="4"/>
        <TextBox Text="{Binding Port1}" Grid.Row="1"
           VerticalContentAlignment="Center" HorizontalContentAlignment="Center"/>
        <TextBox Text="{Binding Port2}" Grid.Row="1" Grid.Column="2"
           VerticalContentAlignment="Center" HorizontalContentAlignment="Center"/>
        <TextBox Text="{Binding Port3}" Grid.Row="1" Grid.Column="4"
           VerticalContentAlignment="Center" HorizontalContentAlignment="Center"/>
        <Button Content="触发相机" Grid.Row="2" Width="100" Height="100"
         Click="ButtonEnter_Click"/>
        <Button Content="触发相机" Grid.Row="2" Grid.Column="2" Width="100" Height="100"
         Click="Button_Click"/>

        <Border Background="#DDD" Width="200" Height="200"
         Grid.Row="2" Grid.Column="4"/>
    </Grid>
</Window>
